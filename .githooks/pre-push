#!/bin/sh
# Block pushes that include common secret patterns.

set -eu

pattern='(mongodb\+srv://|JWT_SECRET=|RAZORPAY_KEY_ID=|RAZORPAY_KEY_SECRET=|SMTP_PASS=|ADMIN_PASSWORD=|ADMIN_PASSWORD_HASH=|ADMIN_RESET_TOKEN_HASH=|API[_-]?KEY=|SECRET=|TOKEN=|KEY_SECRET=)'

fail=0

stdin_file="$(mktemp 2>/dev/null || mktemp -t pre-push.XXXXXX)"
cleanup() {
  if [ -n "$stdin_file" ] && [ -f "$stdin_file" ]; then
    rm -f "$stdin_file"
  fi
}
trap cleanup EXIT

cat > "$stdin_file"

command -v git-lfs >/dev/null 2>&1 || {
  printf >&2 "\n%s\n\n" "This repository is configured for Git LFS but 'git-lfs' was not found on your path. If you no longer wish to use Git LFS, remove this hook by deleting the 'pre-push' file in the hooks directory (set by 'core.hookspath'; usually '.git/hooks').";
  exit 2;
}
git lfs pre-push "$@" < "$stdin_file"

while read -r local_ref local_sha remote_ref remote_sha
do
  # Skip deletes
  if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
    continue
  fi

  # New branch push
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    range="$local_sha"
  else
    range="$remote_sha..$local_sha"
  fi

  # Scan diff for secret-like patterns (skip hooks and env examples)
  for file in $(git diff --name-only "$range"); do
    [ -z "$file" ] && continue
    case "$file" in
      .githooks/pre-push|*.env.example)
        continue
        ;;
    esac
    if git diff --unified=0 "$range" -- "$file" | grep -E -i "$pattern" >/dev/null 2>&1; then
      echo "ERROR: Potential secret detected in commits to be pushed."
      echo "File: $file"
      echo "Fix it before pushing. If this is a false positive, edit .githooks/pre-push."
      fail=1
      break
    fi
  done
done < "$stdin_file"

if [ "$fail" -ne 0 ]; then
  exit 1
fi

exit 0
